# Scalar arithmetic and logic
print(42.0)
print(2.0 + 3.0 * 4.0)
print(10.0 / 3.0)
print(2.0 ** 3.0)
print(2.0 ** 0.5)
print(5.0 * 2.0 ** 3.0)

# Unary operators
print(-5.0)
print(!0.0)
print(!42.0)

# Comparisons and logic
print(3.0 < 5.0)
print(3.0 == 3.0)
print(3.0 != 4.0)
print(1.0 && 0.0)
print(1.0 || 0.0)
