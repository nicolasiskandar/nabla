# Newton-Raphson root finding
#
# Use a couple of fixed Newton steps to approximate a root of f(x) = x^3 - 2x - 5.

fn f(x: matrix[1, 1])
    x[0, 0] * x[0, 0] * x[0, 0] - 2.0 * x[0, 0] - 5.0

let x0: matrix[1, 1] = [2.0] in
let f0 = f(x0) in
let g0 = ∇f(x0) in
let x1 = x0[0, 0] - f0 / g0[0, 0] in
let m1: matrix[1, 1] = [x1] in
let f1 = f(m1) in
let g1 = ∇f(m1) in
let x2 = x1 - f1 / g1[0, 0] in
let m2: matrix[1, 1] = [x2] in
    print(x0[0, 0]) + print(x1) + print(x2) + print(f(m2))